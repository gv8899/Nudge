# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# brainstorming workspace
.superpowers/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# sqlite
*.db
*.db-shm
*.db-wal

# memory
/memory

# Apple / Swift
# Xcode project is generated from apple/project.yml via xcodegen
apple/*.xcodeproj
apple/*.xcworkspace
apple/**/xcuserdata/
apple/**/*.xcuserstate
apple/**/.build/
apple/**/.swiftpm/
apple/**/DerivedData/
# Archive / IPA output from `xcodebuild archive + exportArchive`
apple/build/
# Developer ID provisioning profile — 從 developer.apple.com 下載、放在
# apple/ 給 build-dmg.sh 嵌進 .app/Contents/embedded.provisionprofile。
# 跟憑證一樣不該進 repo（profile 含 cert public key + team identity）。
apple/*.provisionprofile

# Flutter mobile (退役) — i18n sync 還會寫到 mobile/lib/l10n/*.arb，
# 但 Flutter binary 不再 build / ship；產物無 consumer，gitignore 防
# 止每次 sync 完 git status 出現 untracked 噪音。
/mobile/
*.p8
