# Postgres connection (drizzle-orm). Local dev 可以用 postgres@localhost；
# Zeabur 部署可以從 service variables 拿 internal URL。
DATABASE_URL=postgresql://user:password@localhost:5432/nudge

# Google OAuth — auth.js (NextAuth) 的 Web client，**不是** iOS / macOS 那組。
# 從 Google Cloud Console → APIs & Services → Credentials 拿 application type
# = Web application 的 client ID + secret。Authorized redirect URIs 要含
# http://localhost:3000/api/auth/callback/google（dev）跟 prod 對應路徑。
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# JWT signing secret for auth.js sessions. 隨機 32-byte base64：
#   openssl rand -base64 32
AUTH_SECRET=

# Base URL for auth.js — 用來組 callback URL。Dev 是 localhost，prod 換成
# https://nudge.tw（或部署後的 domain）。
AUTH_URL=http://localhost:3000

# 32-byte base64 key for encrypting Google Calendar tokens at rest.
# 跟 AUTH_SECRET 不要共用，獨立一支：
#   openssl rand -base64 32
CALENDAR_TOKEN_KEY=

# Google Calendar OAuth redirect — 必須跟 GCP console 註冊的 redirect URI
# 完全一致。Dev / prod 可以註冊不同 entry。
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/calendar/callback

# ── APNs（即時同步 silent push；iOS 首刀）────────────────────────────────
# Apple Developer 後台 → Keys → 建 APNs Auth Key 下載 .p8。
# APNS_KEY 放 .p8 全文（PEM）；若平台只吃單行，把換行寫成 \n 會自動還原。
# 三個都沒設時後端靜默跳過推播（30s 輪詢兜底），不影響功能。
APNS_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=B9NC8LR2HQ
# bundle id；預設 tw.nudge.app 可不設
# APNS_TOPIC=tw.nudge.app

# ── Paddle Billing（Web/Mac 金流；MoR）──────────────────────────────────
# 先 sandbox 起步（sandbox.paddle.com 免 KYC 即開）；上線切 production 時
# 全部換成 live 值。缺值時 server 照常啟動，金流 API 回 503（lazy 驗證）。
PADDLE_ENV=sandbox
# Paddle Dashboard → Developer tools → Authentication → API key
PADDLE_API_KEY=
# Developer tools → Notifications → 該 webhook 的 secret（驗 Paddle-Signature）
PADDLE_WEBHOOK_SECRET=
# Developer tools → Authentication → Client-side token（前端 Paddle.js 用）
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# Catalog → 同一 Product 下的 4 個 Price id（月/年 × 有 trial/無 trial）。
# trial 版設 7-day trial period；no-trial 版同價無 trial（trial 已用過的人）。
PADDLE_PRICE_MONTHLY_TRIAL=
PADDLE_PRICE_ANNUAL_TRIAL=
PADDLE_PRICE_MONTHLY_NOTRIAL=
PADDLE_PRICE_ANNUAL_NOTRIAL=
# OTT 手遞組結帳 URL 的 base；dev 用 localhost
NEXT_PUBLIC_APP_URL=http://localhost:3000
